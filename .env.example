# Database — use postgresql+asyncpg:// for async driver; Railway provides postgres:// which is auto-converted
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/documents_db

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-must-be-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Rate limiting (slowapi format)
RATE_LIMIT_EXTRACT=5/minute
RATE_LIMIT_API=100/minute

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
# JSON array or comma-separated list
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Seeded admin user (created on first startup if not exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-secure-password
